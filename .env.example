# Copy this file's variable names into Vercel's Project → Settings → Environment Variables.
# Do NOT commit a real .env file with real secrets to GitHub.

# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Your Gmail address that will SEND the contact-form emails
GMAIL_USER=you@gmail.com

# A 16-character Gmail "App Password" (NOT your normal Gmail password).
# Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be turned on for the Gmail account)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where contact-form enquiries should be delivered
CONTACT_TO_EMAIL=info@stylariatech.com

# Restrict which website is allowed to call this backend.
# Use "*" only while testing — set your real domain before going live.
ALLOWED_ORIGIN=https://stylariatech.com
